{
  "name": "amc-backend",
  "version": "5.0.21",
  "displayName": "Interne Applikation AMC",
  "description": "TypeScript + Sequelize + postgres + Express API Server",
  "author": {
    "name": "Janine Franken",
    "email": "janine@olconet.com"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "start": "pnpm run build:swc && node dist/src/server.js",
    "dev": "cross-env NODE_ENV=development nodemon -r .env",
    "postversion": "git push && git push --tags",
    "build": "tsc && tsc-alias",
    "build:swc": "swc src -d dist --source-maps --copy-files",
    "test": "jest --forceExit --detectOpenHandles",
    "lint": "eslint src/",
    "migration:generate": "sequelize migration:generate --name",
    "migration:run": "sequelize db:migrate"
  },
  "keywords": [],
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^9.14.0",
    "@swc/cli": "^0.5.0",
    "@swc/core": "^1.9.1",
    "@types/archiver": "^6.0.3",
    "@types/bcrypt": "^5.0.2",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/eslint__js": "^8.42.3",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.0",
    "@types/formidable": "^3.4.5",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/lodash": "^4.17.13",
    "@types/node": "^22.10.1",
    "@types/nodemailer": "^6.4.16",
    "@types/numeral": "^2.0.5",
    "@types/pdfkit": "^0.13.5",
    "@types/sequelize": "^4.28.20",
    "@types/swagger-ui-express": "^4.1.7",
    "eslint": "^9.14.0",
    "sequelize-auto": "^0.8.8",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.10",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.13.0"
  },
  "dependencies": {
    "@types/uuid": "^10.0.0",
