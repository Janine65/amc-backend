{
  "name": "amc-backend",
  "version": "1.0.0",
  "displayName": "Interne Applikation AMC",
  "description": "TypeScript + Sequelize + postgres + Express API Server",
  "author": {
    "name": "Janine Franken",
    "email": "janine@olconet.com"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "start": "pnpm run build && node dist/src/server.js",
    "dev": "cross-env NODE_ENV=development nodemon -r .env",
    "postversion": "git push && git push --tags",
    "build": "rm -r dist && tsc && tsc-alias",
    "build:swc": "swc src -d dist --source-maps --copy-files",
    "test": "jest --forceExit --detectOpenHandles",
    "lint": "eslint src/",
    "migration:generate": "sequelize migration:generate --name",
    "migration:run": "sequelize db:migrate"
  },
  "keywords": [],
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^9.11.1",
    "@swc/cli": "^0.4.0",
    "@swc/core": "^1.7.26",
    "@types/archiver": "^6.0.2",
    "@types/bcrypt": "^5.0.2",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/eslint__js": "^8.42.3",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.0",
    "@types/formidable": "^3.4.5",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/lodash": "^4.17.7",
    "@types/node": "^22.5.5",
    "@types/nodemailer": "^6.4.16",
    "@types/numeral": "^2.0.5",
    "@types/pdfkit": "^0.13.5",
    "@types/sequelize": "^4.28.20",
    "@types/swagger-ui-express": "^4.1.6",
    "eslint": "^9.11.1",
    "globals": "^15.9.0",
    "sequelize-auto": "^0.8.8",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.10",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.7.0"
  },
  "dependencies": {
    "@types/uuid": "^10.0.0",
    "archiver": "^7.0.1",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "colors": "^1.4.0",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.21.0",
    "express-session": "^1.18.0",
    "formidable": "^3.5.1",
