    "nodeutils": "^1.2.3",
    "numeral": "^2.0.6",
    "pdfkit": "^0.15.0",
    "pdfkit-table": "^0.1.99",
    "pg": "^8.13.0",
    "rxjs": "^7.8.1",
    "sequelize": "^6.37.3",
    "swagger-autogen": "^2.23.7",
